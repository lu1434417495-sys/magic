[gd_scene load_steps=3 format=3]
; Scene purpose: Save list modal scene for slot browsing, descriptions, and close controls.
; Review focus: verify external resources, root-node ownership, and major subtrees stay aligned.


; External scripts, scenes, and shared assets referenced by this scene.
[ext_resource type="Script" path="res://scripts/ui/save_list_window.gd" id="1_l0af2"]
[ext_resource type="StyleBoxFlat" path="res://scenes/ui/styles/panel_default.tres" id="2_panel_default"]

; Root node and primary scene tree.
[node name="SaveListWindow" type="Control"]
visible = false
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_l0af2")

; Modal backdrop that dims the parent scene and blocks background input.
[node name="Shade" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.0196078, 0.027451, 0.0588235, 0.7)

; Centered container that keeps the main panel anchored in the viewport.
[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Panel" type="PanelContainer" parent="CenterContainer"]
