[gd_scene load_steps=3 format=3]
; Scene purpose: Character info modal scene organizing summary, stats, and skill sections.
; Review focus: verify external resources, root-node ownership, and major subtrees stay aligned.


; External scripts, scenes, and shared assets referenced by this scene.
[ext_resource type="Script" path="res://scripts/ui/character_info_window.gd" id="1_g81cw"]
[ext_resource type="StyleBoxFlat" path="res://scenes/ui/styles/panel_default.tres" id="2_panel_default"]

; Root node and primary scene tree.
[node name="CharacterInfoWindow" type="Control"]
visible = false
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_g81cw")

; Modal backdrop that dims the parent scene and blocks background input.
[node name="Shade" type="ColorRect" parent="."]
unique_name_in_owner = true
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.0196078, 0.027451, 0.0588235, 0.7)

; Centered container that keeps the main panel anchored in the viewport.
[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Panel" type="PanelContainer" parent="CenterContainer"]
custom_minimum_size = Vector2(560, 360)
layout_mode = 2
theme_override_styles/panel = ExtResource("2_panel_default")

[node name="MarginContainer" type="MarginContainer" parent="CenterContainer/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 24

[node name="Content" type="VBoxContainer" parent="CenterContainer/Panel/MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="Header" type="HBoxContainer" parent="CenterContainer/Panel/MarginContainer/Content"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="HeaderText" type="VBoxContainer" parent="CenterContainer/Panel/MarginContainer/Content/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="CenterContainer/Panel/MarginContainer/Content/Header/HeaderText"]
unique_name_in_owner = true
layout_mode = 2
theme_override_colors/font_color = Color(1, 1, 1, 1)
theme_override_font_sizes/font_size = 30
text = "人物信息"

[node name="MetaLabel" type="Label" parent="CenterContainer/Panel/MarginContainer/Content/Header/HeaderText"]
