stretch_mode = 6

[node name="AccentGlow" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.16
anchor_top = 0.12
anchor_right = 0.84
anchor_bottom = 0.42
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
