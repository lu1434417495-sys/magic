[sub_resource type="Resource" id="Action_survival_position"]
script = ExtResource("10_adv_pos")
action_id = &"archer_survival_position"
score_bucket_id = &"archer_survival"
target_selector = &"nearest_enemy"
desired_min_distance = 3
desired_max_distance = 5
range_skill_ids = Array[StringName]([&"archer_aimed_shot", &"archer_multishot", &"basic_attack"])
minimum_safe_distance = 3
positioning_mode = &"survival"

