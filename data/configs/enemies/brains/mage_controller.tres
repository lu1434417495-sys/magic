[sub_resource type="Resource" id="Action_blink_escape"]
script = ExtResource("9_reposition")
action_id = &"mage_blink_escape"
score_bucket_id = &"archer_survival"
skill_ids = Array[StringName]([&"mage_blink"])
target_selector = &"nearest_enemy"
minimum_safe_distance = 4
safe_distance_margin = 0
desired_max_distance_bonus = 3

[sub_resource type="Resource" id="Action_survival_position"]
script = ExtResource("8_adv_pos")
action_id = &"mage_survival_position"
score_bucket_id = &"archer_survival"
target_selector = &"nearest_enemy"
desired_min_distance = 4
desired_max_distance = 5
range_skill_ids = Array[StringName]([&"mage_fireball", &"mage_chain_lightning"])
minimum_safe_distance = 4
safe_distance_margin = 1
positioning_mode = &"survival"

[sub_resource type="Resource" id="Action_high_ground_position"]
script = ExtResource("8_adv_pos")
action_id = &"mage_high_ground_position"
