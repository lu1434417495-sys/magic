[sub_resource type="Resource" id="State_retreat"]
script = ExtResource("2_state")
state_id = &"retreat"
actions = Array[Resource]([SubResource("Action_blink_escape"), SubResource("Action_survival_position"), SubResource("Action_fireball"), SubResource("Action_chain_lightning"), SubResource("Action_protective_gust"), SubResource("Action_retreat_move"), SubResource("Action_wait")])
