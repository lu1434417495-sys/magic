[sub_resource type="Resource" id="Condition_retreat_low_hp"]
script = ExtResource("12_transition_condition")
predicate = &"self_hp_at_or_below_basis_points"
basis_points = 6500

[sub_resource type="Resource" id="Condition_pressure_current"]
script = ExtResource("12_transition_condition")
predicate = &"current_state_is"
state_ids = Array[StringName]([&"pressure"])

[sub_resource type="Resource" id="Condition_pressure_sticky_distance"]
script = ExtResource("12_transition_condition")
predicate = &"nearest_enemy_distance_at_or_below"
max_distance = 6

[sub_resource type="Resource" id="Condition_pressure_enter_distance"]
script = ExtResource("12_transition_condition")
predicate = &"nearest_enemy_distance_at_or_below"
max_distance = 5

[sub_resource type="Resource" id="Condition_always"]
script = ExtResource("12_transition_condition")
predicate = &"always"

[sub_resource type="Resource" id="Rule_retreat_low_hp"]
script = ExtResource("11_transition_rule")
rule_id = &"retreat_low_hp"
order = 10
target_state_id = &"retreat"
conditions = Array[Resource]([SubResource("Condition_retreat_low_hp")])

[sub_resource type="Resource" id="Rule_pressure_sticky"]
script = ExtResource("11_transition_rule")
rule_id = &"pressure_sticky"
order = 30
from_state_ids = Array[StringName]([&"pressure"])
target_state_id = &"pressure"
conditions = Array[Resource]([SubResource("Condition_pressure_current"), SubResource("Condition_pressure_sticky_distance")])

[sub_resource type="Resource" id="Rule_pressure_enter"]
script = ExtResource("11_transition_rule")
rule_id = &"pressure_enter"
order = 40
target_state_id = &"pressure"
conditions = Array[Resource]([SubResource("Condition_pressure_enter_distance")])

[sub_resource type="Resource" id="Rule_engage_default"]
script = ExtResource("11_transition_rule")
rule_id = &"engage_default"
order = 90
target_state_id = &"engage"
conditions = Array[Resource]([SubResource("Condition_always")])

[resource]
script = ExtResource("1_brain")
brain_id = &"mage_controller"
default_state_id = &"pressure"
states = Array[Resource]([SubResource("State_engage"), SubResource("State_pressure"), SubResource("State_retreat")])
transition_rules = Array[Resource]([SubResource("Rule_retreat_low_hp"), SubResource("Rule_pressure_sticky"), SubResource("Rule_pressure_enter"), SubResource("Rule_engage_default")])
