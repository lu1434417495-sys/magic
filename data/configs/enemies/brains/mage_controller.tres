[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_blink_escape"), SubResource("Action_survival_position"), SubResource("Action_protective_gust"), SubResource("Action_control_cone"), SubResource("Action_fireball"), SubResource("Action_chain_lightning"), SubResource("Action_take_position"), SubResource("Action_wait")])
