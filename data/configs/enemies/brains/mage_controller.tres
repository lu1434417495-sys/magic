minimum_safe_distance = 4
safe_distance_margin = 1
positioning_mode = &"high_ground"

[sub_resource type="Resource" id="Action_control_cone"]
script = ExtResource("3_ground")
action_id = &"mage_control_cone"
score_bucket_id = &"mist_control"
skill_ids = Array[StringName]([&"mage_cone_of_cold", &"mage_gust_of_wind"])
minimum_hit_count = 2
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_coord"

[sub_resource type="Resource" id="Action_protective_gust"]
script = ExtResource("3_ground")
