[ext_resource type="Script" path="res://scripts/enemies/actions/retreat_action.gd" id="7_retreat"]
[ext_resource type="Script" path="res://scripts/enemies/actions/move_to_advantage_position_action.gd" id="8_adv_pos"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_ground_reposition_skill_action.gd" id="9_reposition"]
