[sub_resource type="Resource" id="Action_pressure_aoe"]
script = ExtResource("3_ground")
action_id = &"mist_aoe"
score_bucket_id = &"mist_offense"
skill_ids = Array[StringName]([&"mage_fireball"])
minimum_hit_count = 2
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_coord"

[sub_resource type="Resource" id="Action_pressure_single"]
script = ExtResource("4_unit")
action_id = &"mist_ranged_single"
score_bucket_id = &"mist_offense"
skill_ids = Array[StringName]([&"mage_ice_lance", &"basic_attack"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_pressure_move"]
script = ExtResource("5_move")
