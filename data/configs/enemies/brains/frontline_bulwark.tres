[gd_resource type="Resource" script_class="EnemyAiBrainDef" format=3]

[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_brain_def.gd" id="1_brain"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_state_def.gd" id="2_state"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_charge_action.gd" id="3_charge"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_unit_skill_action.gd" id="4_unit"]
[ext_resource type="Script" path="res://scripts/enemies/actions/move_to_range_action.gd" id="5_move"]
[ext_resource type="Script" path="res://scripts/enemies/actions/wait_action.gd" id="6_wait"]
[ext_resource type="Script" path="res://scripts/enemies/actions/retreat_action.gd" id="7_retreat"]

[sub_resource type="Resource" id="Action_engage_charge"]
script = ExtResource("3_charge")
action_id = &"vanguard_charge_open"
score_bucket_id = &"charge_open"
skill_id = &"charge"
target_selector = &"nearest_enemy"

[sub_resource type="Resource" id="Action_engage_taunt"]
script = ExtResource("4_unit")
action_id = &"vanguard_taunt_open"
skill_ids = Array[StringName]([&"warrior_taunt"])
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_engage_move"]
script = ExtResource("5_move")
action_id = &"vanguard_close_in"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="Action_wait"]
script = ExtResource("6_wait")
action_id = &"vanguard_wait"

[sub_resource type="Resource" id="State_engage"]
script = ExtResource("2_state")
state_id = &"engage"
actions = Array[Resource]([SubResource("Action_engage_charge"), SubResource("Action_engage_taunt"), SubResource("Action_engage_move"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_pressure_bash"]
script = ExtResource("4_unit")
action_id = &"vanguard_shield_bash"
skill_ids = Array[StringName]([&"warrior_shield_bash", &"basic_attack"])
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_pressure_taunt"]
script = ExtResource("4_unit")
action_id = &"vanguard_taunt_pressure"
skill_ids = Array[StringName]([&"warrior_taunt"])
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_pressure_move"]
script = ExtResource("5_move")
action_id = &"vanguard_hold_line"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_pressure_bash"), SubResource("Action_pressure_taunt"), SubResource("Action_pressure_move"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_support_guard"]
script = ExtResource("4_unit")
action_id = &"vanguard_guard_self"
score_bucket_id = &"frontline_guard"
skill_ids = Array[StringName]([&"warrior_guard"])
target_selector = &"self"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="State_support"]
script = ExtResource("2_state")
state_id = &"support"
actions = Array[Resource]([SubResource("Action_support_guard"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_retreat_guard"]
script = ExtResource("4_unit")
action_id = &"vanguard_guard_retreat"
score_bucket_id = &"frontline_guard"
skill_ids = Array[StringName]([&"warrior_guard"])
target_selector = &"self"
desired_min_distance = 2
desired_max_distance = 2
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="Action_retreat_move"]
script = ExtResource("7_retreat")
action_id = &"vanguard_retreat"
minimum_safe_distance = 2

[sub_resource type="Resource" id="State_retreat"]
script = ExtResource("2_state")
state_id = &"retreat"
actions = Array[Resource]([SubResource("Action_retreat_guard"), SubResource("Action_retreat_move"), SubResource("Action_wait")])

[resource]
script = ExtResource("1_brain")
brain_id = &"frontline_bulwark"
default_state_id = &"engage"
retreat_hp_basis_points = 2500
support_hp_basis_points = 5500
pressure_distance = 1
states = Array[Resource]([SubResource("State_engage"), SubResource("State_pressure"), SubResource("State_support"), SubResource("State_retreat")])
