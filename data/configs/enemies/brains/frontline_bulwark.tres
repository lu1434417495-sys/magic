[sub_resource type="Resource" id="Action_support_guard"]
script = ExtResource("4_unit")
action_id = &"vanguard_guard_self"
score_bucket_id = &"frontline_guard"
skill_ids = Array[StringName]([&"warrior_guard"])
target_selector = &"self"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="Slot_support_guard"]
script = ExtResource("8_slot")
slot_id = &"support_guard"
slot_role = &"support"
order = 10
allowed_affordances = Array[StringName]([&"self_or_ally_buff", &"ally_heal"])
action_families = Array[StringName]([&"use_unit_skill"])
style_template_action_id = &"vanguard_guard_self"
score_bucket_id = &"frontline_guard"
target_selector = &"self"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="State_support"]
script = ExtResource("2_state")
state_id = &"support"
actions = Array[Resource]([SubResource("Action_support_guard"), SubResource("Action_wait")])
generation_slots = Array[Resource]([SubResource("Slot_support_guard")])

[sub_resource type="Resource" id="Action_retreat_guard"]
script = ExtResource("4_unit")
action_id = &"vanguard_guard_retreat"
score_bucket_id = &"frontline_guard"
skill_ids = Array[StringName]([&"warrior_guard"])
target_selector = &"self"
desired_min_distance = 2
desired_max_distance = 2
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="Action_retreat_move"]
script = ExtResource("7_retreat")
action_id = &"vanguard_retreat"
minimum_safe_distance = 2

[sub_resource type="Resource" id="Slot_retreat_guard"]
script = ExtResource("8_slot")
slot_id = &"retreat_guard"
slot_role = &"survival"
order = 10
allowed_affordances = Array[StringName]([&"self_or_ally_buff", &"ally_heal", &"unit_hostile.control"])
action_families = Array[StringName]([&"use_unit_skill"])
style_template_action_id = &"vanguard_guard_retreat"
score_bucket_id = &"frontline_guard"
target_selector = &"self"
desired_min_distance = 2
desired_max_distance = 2
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="State_retreat"]
script = ExtResource("2_state")
state_id = &"retreat"
actions = Array[Resource]([SubResource("Action_retreat_guard"), SubResource("Action_retreat_move"), SubResource("Action_wait")])
generation_slots = Array[Resource]([SubResource("Slot_retreat_guard")])

[sub_resource type="Resource" id="Condition_retreat_low_hp"]
script = ExtResource("10_transition_condition")
predicate = &"self_hp_at_or_below_basis_points"
basis_points = 2500

[sub_resource type="Resource" id="Condition_support_self_low_hp"]
script = ExtResource("10_transition_condition")
predicate = &"self_hp_at_or_below_basis_points"
basis_points = 5500

[sub_resource type="Resource" id="Condition_support_ally_low_hp"]
script = ExtResource("10_transition_condition")
predicate = &"ally_hp_at_or_below_basis_points"
basis_points = 5500

[sub_resource type="Resource" id="Condition_support_affordance"]
script = ExtResource("10_transition_condition")
predicate = &"has_skill_affordance"
affordances = Array[StringName]([&"ally_heal", &"self_or_ally_buff"])

[sub_resource type="Resource" id="Condition_pressure_current"]
script = ExtResource("10_transition_condition")
predicate = &"current_state_is"
state_ids = Array[StringName]([&"pressure"])

[sub_resource type="Resource" id="Condition_pressure_sticky_distance"]
script = ExtResource("10_transition_condition")
predicate = &"nearest_enemy_distance_at_or_below"
max_distance = 2

[sub_resource type="Resource" id="Condition_pressure_enter_distance"]
script = ExtResource("10_transition_condition")
predicate = &"nearest_enemy_distance_at_or_below"
max_distance = 1

[sub_resource type="Resource" id="Condition_always"]
script = ExtResource("10_transition_condition")
predicate = &"always"

[sub_resource type="Resource" id="Rule_retreat_low_hp"]
script = ExtResource("9_transition_rule")
rule_id = &"retreat_low_hp"
order = 10
target_state_id = &"retreat"
conditions = Array[Resource]([SubResource("Condition_retreat_low_hp")])

[sub_resource type="Resource" id="Rule_support_self_low_hp"]
script = ExtResource("9_transition_rule")
rule_id = &"support_self_low_hp"
order = 20
target_state_id = &"support"
conditions = Array[Resource]([SubResource("Condition_support_self_low_hp"), SubResource("Condition_support_affordance")])

[sub_resource type="Resource" id="Rule_support_ally_low_hp"]
script = ExtResource("9_transition_rule")
rule_id = &"support_ally_low_hp"
order = 21
target_state_id = &"support"
conditions = Array[Resource]([SubResource("Condition_support_ally_low_hp"), SubResource("Condition_support_affordance")])

[sub_resource type="Resource" id="Rule_pressure_sticky"]
script = ExtResource("9_transition_rule")
rule_id = &"pressure_sticky"
order = 30
from_state_ids = Array[StringName]([&"pressure"])
target_state_id = &"pressure"
conditions = Array[Resource]([SubResource("Condition_pressure_current"), SubResource("Condition_pressure_sticky_distance")])

[sub_resource type="Resource" id="Rule_pressure_enter"]
script = ExtResource("9_transition_rule")
rule_id = &"pressure_enter"
order = 40
target_state_id = &"pressure"
conditions = Array[Resource]([SubResource("Condition_pressure_enter_distance")])

[sub_resource type="Resource" id="Rule_engage_default"]
script = ExtResource("9_transition_rule")
rule_id = &"engage_default"
order = 90
target_state_id = &"engage"
conditions = Array[Resource]([SubResource("Condition_always")])

[resource]
script = ExtResource("1_brain")
brain_id = &"frontline_bulwark"
default_state_id = &"engage"
states = Array[Resource]([SubResource("State_engage"), SubResource("State_pressure"), SubResource("State_support"), SubResource("State_retreat")])
transition_rules = Array[Resource]([SubResource("Rule_retreat_low_hp"), SubResource("Rule_support_self_low_hp"), SubResource("Rule_support_ally_low_hp"), SubResource("Rule_pressure_sticky"), SubResource("Rule_pressure_enter"), SubResource("Rule_engage_default")])
