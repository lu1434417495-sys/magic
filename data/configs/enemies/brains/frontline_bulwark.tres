[gd_resource type="Resource" script_class="EnemyAiBrainDef" format=3]

[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_brain_def.gd" id="1_brain"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_state_def.gd" id="2_state"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_charge_action.gd" id="3_charge"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_unit_skill_action.gd" id="4_unit"]
[ext_resource type="Script" path="res://scripts/enemies/actions/move_to_range_action.gd" id="5_move"]
[ext_resource type="Script" path="res://scripts/enemies/actions/wait_action.gd" id="6_wait"]
[ext_resource type="Script" path="res://scripts/enemies/actions/retreat_action.gd" id="7_retreat"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_generation_slot_def.gd" id="8_slot"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_transition_rule_def.gd" id="9_transition_rule"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_transition_condition_def.gd" id="10_transition_condition"]

[sub_resource type="Resource" id="Action_engage_charge"]
script = ExtResource("3_charge")
action_id = &"vanguard_charge_open"
score_bucket_id = &"charge_open"
skill_id = &"charge"
target_selector = &"nearest_enemy"

[sub_resource type="Resource" id="Action_engage_taunt"]
script = ExtResource("4_unit")
action_id = &"vanguard_taunt_open"
skill_ids = Array[StringName]([&"warrior_taunt"])
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_engage_move"]
script = ExtResource("5_move")
action_id = &"vanguard_close_in"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="Action_wait"]
script = ExtResource("6_wait")
action_id = &"vanguard_wait"

[sub_resource type="Resource" id="Slot_engage_charge_path"]
script = ExtResource("8_slot")
slot_id = &"engage_charge_path"
slot_role = &"engage"
order = 10
allowed_affordances = Array[StringName]([&"charge_path_aoe"])
action_families = Array[StringName]([&"use_charge_path_aoe"])
style_template_action_id = &"vanguard_charge_open"
score_bucket_id = &"charge_open"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="Slot_engage_charge"]
script = ExtResource("8_slot")
slot_id = &"engage_charge"
slot_role = &"engage"
order = 20
allowed_affordances = Array[StringName]([&"charge_engage"])
action_families = Array[StringName]([&"use_charge"])
style_template_action_id = &"vanguard_charge_open"
score_bucket_id = &"charge_open"
target_selector = &"nearest_enemy"

[sub_resource type="Resource" id="Slot_engage_unit"]
script = ExtResource("8_slot")
slot_id = &"engage_unit"
slot_role = &"offense"
order = 30
allowed_affordances = Array[StringName]([&"unit_hostile.damage", &"unit_hostile.control", &"displacement_control"])
action_families = Array[StringName]([&"use_unit_skill"])
style_template_action_id = &"vanguard_taunt_open"
score_bucket_id = &"frontline_guard"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Slot_engage_move"]
script = ExtResource("8_slot")
slot_id = &"engage_move"
slot_role = &"positioning"
order = 40
allowed_affordances = Array[StringName]([&"random_chain", &"unit_hostile.damage", &"unit_hostile.control"])
action_families = Array[StringName]([&"move_to_range"])
style_template_action_id = &"vanguard_close_in"
score_bucket_id = &"charge_open"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="State_engage"]
script = ExtResource("2_state")
state_id = &"engage"
actions = Array[Resource]([SubResource("Action_engage_charge"), SubResource("Action_engage_taunt"), SubResource("Action_engage_move"), SubResource("Action_wait")])
generation_slots = Array[Resource]([SubResource("Slot_engage_charge_path"), SubResource("Slot_engage_charge"), SubResource("Slot_engage_unit"), SubResource("Slot_engage_move")])

