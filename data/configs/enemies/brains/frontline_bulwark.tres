[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_pressure_bash"), SubResource("Action_pressure_taunt"), SubResource("Action_pressure_move"), SubResource("Action_wait")])
