[sub_resource type="Resource" id="Action_control"]
script = ExtResource("3_unit")
action_id = &"weaver_lock_target"
score_bucket_id = &"mist_control"
skill_ids = Array[StringName]([&"mage_glacial_prison", &"basic_attack"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_unit"

