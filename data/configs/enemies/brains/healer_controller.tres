[gd_resource type="Resource" script_class="EnemyAiBrainDef" format=3]

[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_brain_def.gd" id="1_brain"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_state_def.gd" id="2_state"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_unit_skill_action.gd" id="3_unit"]
[ext_resource type="Script" path="res://scripts/enemies/actions/move_to_range_action.gd" id="4_move"]
[ext_resource type="Script" path="res://scripts/enemies/actions/wait_action.gd" id="5_wait"]
[ext_resource type="Script" path="res://scripts/enemies/actions/retreat_action.gd" id="6_retreat"]

[sub_resource type="Resource" id="Action_control"]
script = ExtResource("3_unit")
action_id = &"weaver_lock_target"
score_bucket_id = &"mist_control"
skill_ids = Array[StringName]([&"mage_glacial_prison"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_pressure"]
script = ExtResource("3_unit")
action_id = &"weaver_pressure_bolt"
score_bucket_id = &"mist_offense"
skill_ids = Array[StringName]([&"mage_ice_lance"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_move"]
script = ExtResource("4_move")
action_id = &"weaver_take_position"
target_selector = &"nearest_enemy"
desired_min_distance = 3
desired_max_distance = 4

[sub_resource type="Resource" id="Action_move_pressure"]
script = ExtResource("4_move")
action_id = &"weaver_keep_range"
target_selector = &"nearest_enemy"
desired_min_distance = 3
desired_max_distance = 4

[sub_resource type="Resource" id="Action_wait"]
script = ExtResource("5_wait")
action_id = &"weaver_wait"

[sub_resource type="Resource" id="State_engage"]
script = ExtResource("2_state")
state_id = &"engage"
actions = Array[Resource]([SubResource("Action_control"), SubResource("Action_pressure"), SubResource("Action_move"), SubResource("Action_wait")])

[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_control"), SubResource("Action_pressure"), SubResource("Action_move_pressure"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_support_heal"]
script = ExtResource("3_unit")
action_id = &"weaver_rewind_ally"
score_bucket_id = &"mist_support"
skill_ids = Array[StringName]([&"mage_temporal_rewind"])
target_selector = &"lowest_hp_ally"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="Action_support_bind"]
script = ExtResource("3_unit")
action_id = &"weaver_cover_bind"
score_bucket_id = &"mist_control"
skill_ids = Array[StringName]([&"mage_glacial_prison"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 3
desired_max_distance = 4
distance_reference = &"target_unit"

[sub_resource type="Resource" id="State_support"]
script = ExtResource("2_state")
state_id = &"support"
actions = Array[Resource]([SubResource("Action_support_heal"), SubResource("Action_support_bind"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_retreat_heal"]
script = ExtResource("3_unit")
action_id = &"weaver_rewind_retreat"
score_bucket_id = &"mist_support"
skill_ids = Array[StringName]([&"mage_temporal_rewind"])
target_selector = &"lowest_hp_ally"
desired_min_distance = 4
desired_max_distance = 4
distance_reference = &"enemy_frontline"

[sub_resource type="Resource" id="Action_retreat_move"]
script = ExtResource("6_retreat")
action_id = &"weaver_retreat"
minimum_safe_distance = 4

[sub_resource type="Resource" id="State_retreat"]
script = ExtResource("2_state")
state_id = &"retreat"
actions = Array[Resource]([SubResource("Action_retreat_heal"), SubResource("Action_retreat_move"), SubResource("Action_wait")])

[resource]
script = ExtResource("1_brain")
brain_id = &"healer_controller"
default_state_id = &"pressure"
retreat_hp_ratio = 0.35
support_hp_ratio = 0.7
pressure_distance = 4
states = Array[Resource]([SubResource("State_engage"), SubResource("State_pressure"), SubResource("State_support"), SubResource("State_retreat")])
