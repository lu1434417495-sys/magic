[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_pressure_lane"), SubResource("Action_pressure_pin"), SubResource("Action_pressure_move"), SubResource("Action_melee_fallback_move"), SubResource("Action_wait")])
generation_slots = Array[Resource]([SubResource("Slot_pressure_ground"), SubResource("Slot_pressure_unit"), SubResource("Slot_pressure_move")])

