[sub_resource type="Resource" id="State_engage"]
script = ExtResource("2_state")
state_id = &"engage"
actions = Array[Resource]([SubResource("Action_pressure_lane"), SubResource("Action_pressure_pin"), SubResource("Action_engage_move"), SubResource("Action_melee_fallback_move"), SubResource("Action_wait")])
generation_slots = Array[Resource]([SubResource("Slot_engage_ground"), SubResource("Slot_engage_unit"), SubResource("Slot_engage_move")])

[sub_resource type="Resource" id="Slot_retreat_unit"]
script = ExtResource("8_slot")
slot_id = &"retreat_unit"
slot_role = &"survival"
order = 10
allowed_affordances = Array[StringName]([&"unit_hostile.damage", &"unit_hostile.control", &"random_chain"])
action_families = Array[StringName]([&"use_unit_skill", &"use_random_chain_skill"])
