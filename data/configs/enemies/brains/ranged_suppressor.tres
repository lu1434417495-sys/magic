[gd_resource type="Resource" script_class="EnemyAiBrainDef" format=3]

[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_brain_def.gd" id="1_brain"]
[ext_resource type="Script" path="res://scripts/enemies/enemy_ai_state_def.gd" id="2_state"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_ground_skill_action.gd" id="3_ground"]
[ext_resource type="Script" path="res://scripts/enemies/actions/use_unit_skill_action.gd" id="4_unit"]
[ext_resource type="Script" path="res://scripts/enemies/actions/move_to_range_action.gd" id="5_move"]
[ext_resource type="Script" path="res://scripts/enemies/actions/wait_action.gd" id="6_wait"]
[ext_resource type="Script" path="res://scripts/enemies/actions/retreat_action.gd" id="7_retreat"]

[sub_resource type="Resource" id="Action_pressure_lane"]
script = ExtResource("3_ground")
action_id = &"harrier_suppress_lane"
score_bucket_id = &"harrier_pressure"
skill_ids = Array[StringName]([&"archer_suppressive_fire"])
minimum_hit_count = 2
desired_min_distance = 4
desired_max_distance = 5
distance_reference = &"target_coord"

[sub_resource type="Resource" id="Action_pressure_pin"]
script = ExtResource("4_unit")
action_id = &"harrier_pin_target"
score_bucket_id = &"harrier_pressure"
skill_ids = Array[StringName]([&"archer_pinning_shot", &"basic_attack"])
target_selector = &"lowest_hp_enemy"
desired_min_distance = 4
desired_max_distance = 5
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_engage_move"]
script = ExtResource("5_move")
action_id = &"harrier_take_cover"
target_selector = &"nearest_enemy"
desired_min_distance = 4
desired_max_distance = 5

[sub_resource type="Resource" id="Action_pressure_move"]
script = ExtResource("5_move")
action_id = &"harrier_keep_range"
target_selector = &"nearest_enemy"
desired_min_distance = 4
desired_max_distance = 5

[sub_resource type="Resource" id="Action_melee_fallback_move"]
script = ExtResource("5_move")
action_id = &"harrier_close_for_basic_attack"
target_selector = &"nearest_enemy"
desired_min_distance = 1
desired_max_distance = 1

[sub_resource type="Resource" id="Action_wait"]
script = ExtResource("6_wait")
action_id = &"harrier_wait"

[sub_resource type="Resource" id="State_engage"]
script = ExtResource("2_state")
state_id = &"engage"
actions = Array[Resource]([SubResource("Action_pressure_lane"), SubResource("Action_pressure_pin"), SubResource("Action_engage_move"), SubResource("Action_melee_fallback_move"), SubResource("Action_wait")])

[sub_resource type="Resource" id="State_pressure"]
script = ExtResource("2_state")
state_id = &"pressure"
actions = Array[Resource]([SubResource("Action_pressure_lane"), SubResource("Action_pressure_pin"), SubResource("Action_pressure_move"), SubResource("Action_melee_fallback_move"), SubResource("Action_wait")])

[sub_resource type="Resource" id="Action_retreat_cover"]
script = ExtResource("4_unit")
action_id = &"harrier_cover_retreat"
skill_ids = Array[StringName]([&"archer_pinning_shot", &"basic_attack"])
target_selector = &"nearest_enemy"
desired_min_distance = 5
desired_max_distance = 5
distance_reference = &"target_unit"

[sub_resource type="Resource" id="Action_retreat_move"]
script = ExtResource("7_retreat")
action_id = &"harrier_retreat"
minimum_safe_distance = 5

[sub_resource type="Resource" id="State_retreat"]
script = ExtResource("2_state")
state_id = &"retreat"
actions = Array[Resource]([SubResource("Action_retreat_cover"), SubResource("Action_retreat_move"), SubResource("Action_wait")])

[resource]
script = ExtResource("1_brain")
brain_id = &"ranged_suppressor"
default_state_id = &"pressure"
retreat_hp_ratio = 0.3
pressure_distance = 4
states = Array[Resource]([SubResource("State_engage"), SubResource("State_pressure"), SubResource("State_retreat")])
