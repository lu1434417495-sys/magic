"drop_id": &"wolf_hide",
"drop_type": &"item",
"item_id": &"beast_hide",
"quantity": 1
}])
attribute_overrides = {
"hp_max": 28,
"mp_max": 0,
"stamina_max": 3,
"action_points": 2,
"attack_bonus": 5,
"armor_class": 13,
"armor_ac_bonus": 0,
"weapon_attack_range": 1,
"weapon_physical_damage_tag": &"physical_pierce",
}
