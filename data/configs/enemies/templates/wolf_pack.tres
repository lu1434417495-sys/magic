[gd_resource type="Resource" script_class="EnemyTemplateDef" format=3]

[ext_resource type="Script" path="res://scripts/enemies/enemy_template_def.gd" id="1_template"]

[resource]
script = ExtResource("1_template")
template_id = &"wolf_pack"
display_name = "荒狼群"
