[gd_resource type="Resource" script_class="ProfessionDef" load_steps=18 format=3]

[ext_resource type="Script" path="res://scripts/player/progression/profession_def.gd" id="1_profession"]
[ext_resource type="Script" path="res://scripts/player/progression/profession_promotion_requirement.gd" id="2_unlock"]
[ext_resource type="Script" path="res://scripts/player/progression/tag_requirement.gd" id="3_tag"]
[ext_resource type="Script" path="res://scripts/player/progression/profession_rank_requirement.gd" id="4_rank"]
[ext_resource type="Script" path="res://scripts/player/progression/profession_granted_skill.gd" id="5_granted"]

[sub_resource type="Resource" id="Resource_unlock_archer_learned"]
script = ExtResource("3_tag")
tag = "archer"
count = 2
skill_state = "learned"
origin_filter = "unmerged_only"
selection_role = "qualifier"

[sub_resource type="Resource" id="Resource_unlock_archer_core"]
script = ExtResource("3_tag")
tag = "archer"
count = 1
skill_state = "core_max"
origin_filter = "unmerged_only"
selection_role = "assigned_core"

[sub_resource type="Resource" id="Resource_unlock_requirement"]
script = ExtResource("2_unlock")
required_tag_rules = Array[Resource]([SubResource("Resource_unlock_archer_learned"), SubResource("Resource_unlock_archer_core")])
assigned_core_must_be_subset_of_qualifiers = true

[sub_resource type="Resource" id="Resource_rank_2_archer"]
script = ExtResource("3_tag")
tag = "archer"
count = 2
skill_state = "core_max"
origin_filter = "unmerged_only"
selection_role = "assigned_core"

[sub_resource type="Resource" id="Resource_rank_2_requirement"]
script = ExtResource("4_rank")
target_rank = 2
required_tag_rules = Array[Resource]([SubResource("Resource_rank_2_archer")])

[sub_resource type="Resource" id="Resource_rank_3_archer"]
script = ExtResource("3_tag")
tag = "archer"
count = 2
skill_state = "core_max"
origin_filter = "unmerged_only"
selection_role = "assigned_core"

[sub_resource type="Resource" id="Resource_rank_3_requirement"]
script = ExtResource("4_rank")
target_rank = 3
required_tag_rules = Array[Resource]([SubResource("Resource_rank_3_archer")])

[sub_resource type="Resource" id="Resource_rank_4_archer"]
script = ExtResource("3_tag")
tag = "archer"
count = 3
skill_state = "core_max"
origin_filter = "unmerged_only"
selection_role = "assigned_core"

[sub_resource type="Resource" id="Resource_rank_4_requirement"]
script = ExtResource("4_rank")
target_rank = 4
required_tag_rules = Array[Resource]([SubResource("Resource_rank_4_archer")])

[sub_resource type="Resource" id="Resource_rank_5_archer"]
script = ExtResource("3_tag")
tag = "archer"
count = 3
skill_state = "core_max"
origin_filter = "unmerged_only"
selection_role = "assigned_core"

[sub_resource type="Resource" id="Resource_rank_5_requirement"]
script = ExtResource("4_rank")
target_rank = 5
required_tag_rules = Array[Resource]([SubResource("Resource_rank_5_archer")])

[sub_resource type="Resource" id="Resource_grant_shooting_specialization"]
script = ExtResource("5_granted")
skill_id = &"archer_shooting_specialization"
unlock_rank = 1
skill_type = &"passive"

[resource]
script = ExtResource("1_profession")
profession_id = "archer"
display_name = "弓箭手"
description = "围绕中远距离点杀、牵制和区域火力展开的远程职业。"
max_rank = 5
hit_die_sides = 8
is_initial_profession = true
unlock_requirement = SubResource("Resource_unlock_requirement")
rank_requirements = Array[Resource]([SubResource("Resource_rank_2_requirement"), SubResource("Resource_rank_3_requirement"), SubResource("Resource_rank_4_requirement"), SubResource("Resource_rank_5_requirement")])
granted_skills = Array[Resource]([SubResource("Resource_grant_shooting_specialization")])
