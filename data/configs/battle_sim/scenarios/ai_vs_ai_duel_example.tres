[gd_resource type="Resource" script_class="BattleSimScenarioDef" format=3]

[ext_resource type="Script" path="res://scripts/systems/battle/sim/battle_sim_scenario_def.gd" id="1_scenario"]
[ext_resource type="Script" path="res://scripts/systems/battle/sim/battle_sim_unit_spec.gd" id="2_unit"]

[sub_resource type="Resource" id="Resource_player_vanguard"]
script = ExtResource("2_unit")
unit_id = &"player_vanguard_ai"
display_name = "先锋斗士"
faction_id = &"player"
control_mode = &"ai"
ai_brain_id = &"melee_aggressor"
ai_state_id = &"engage"
coord = Vector2i(0, 1)
current_hp = 48
current_stamina = 3
current_ap = 2
action_threshold = 110
attribute_overrides = {
"hp_max": 48,
"stamina_max": 3,
"action_points": 2,
"attack_bonus": 6,
"armor_class": 15,
"armor_ac_bonus": 0
}
skill_ids = Array[StringName]([&"charge", &"warrior_heavy_strike"])
skill_level_map = {
"charge": 1,
"warrior_heavy_strike": 1
}

[sub_resource type="Resource" id="Resource_enemy_harrier"]
script = ExtResource("2_unit")
unit_id = &"enemy_harrier_ai"
