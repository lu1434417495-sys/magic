"archer_pinning_shot": 1
}

[resource]
script = ExtResource("1_scenario")
scenario_id = &"ai_vs_ai_duel_example"
display_name = "AI vs AI Duel Example"
description = "用于验证 player/hostile 双方都由 AI 驱动时的整场战斗模拟。"
map_size = Vector2i(6, 3)
ally_units = Array[Resource]([SubResource("Resource_player_vanguard")])
enemy_units = Array[Resource]([SubResource("Resource_enemy_harrier")])
timeline_ticks_per_step = 1
tu_per_tick = 5
max_iterations = 400
seeds = PackedInt32Array(301, 302)
