[resource]
script = ExtResource("1_scenario")
scenario_id = &"formal_canyon_wolf_pack_mirror_20_rounds"
display_name = "Formal Canyon Wolf Pack Mirror 10 Rounds"
description = "正式 canyon 地图上 2 只狼对 2 只狼，双方都使用 melee_aggressor 狼系 AI，固定 10 个 seed 做镜像对战。"
map_size = Vector2i(19, 11)
terrain_profile_id = &"canyon"
use_formal_terrain_generation = true
world_coord = Vector2i(7, 11)
ally_units = Array[Resource]([SubResource("Resource_ally_wolf_01"), SubResource("Resource_ally_wolf_02")])
enemy_units = Array[Resource]([SubResource("Resource_enemy_wolf_01"), SubResource("Resource_enemy_wolf_02")])
timeline_ticks_per_step = 1
tu_per_tick = 5
max_iterations = 1500
manual_policy = &"wait"
trace_enabled = false
seeds = PackedInt32Array(5101, 5102, 5103, 5104, 5105, 5106, 5107, 5108, 5109, 5110)
