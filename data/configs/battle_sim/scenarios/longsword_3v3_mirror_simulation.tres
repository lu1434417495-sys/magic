[resource]
script = ExtResource("1_scenario")
scenario_id = &"longsword_3v3_mirror_simulation"
display_name = "Longsword 3v3 Mirror Simulation"
description = "正式 canyon 地图上 3 名钢制长剑手对 3 名钢制长剑手，双方都使用 melee_aggressor AI，携带冲锋与重击技能，使用属性化六维与武器投影。"
map_size = Vector2i(19, 11)
terrain_profile_id = &"canyon"
use_formal_terrain_generation = true
world_coord = Vector2i(7, 11)
ally_units = Array[Resource]([SubResource("Resource_ally_01"), SubResource("Resource_ally_02"), SubResource("Resource_ally_03")])
enemy_units = Array[Resource]([SubResource("Resource_enemy_01"), SubResource("Resource_enemy_02"), SubResource("Resource_enemy_03")])
timeline_ticks_per_step = 1
tu_per_tick = 5
max_iterations = 3000
manual_policy = &"wait"
trace_enabled = true
seeds = PackedInt32Array(101, 102, 103, 104, 105)
