[gd_resource type="Resource" script_class="BattleSimProfileDef" format=3]

[ext_resource type="Script" path="res://scripts/systems/battle_sim_profile_def.gd" id="1_profile"]
[ext_resource type="Script" path="res://scripts/systems/battle_ai_score_profile.gd" id="2_score"]

[sub_resource type="Resource" id="Resource_score"]
script = ExtResource("2_score")

[resource]
script = ExtResource("1_profile")
profile_id = &"pinning_shot_blocked"
display_name = "Pinning Shot Blocked"
description = "通过提高体力消耗禁用钉射，验证 AI 是否会退回到压制射击。"
ai_score_profile = SubResource("Resource_score")
override_patches = Array[Dictionary]([{
"target_type": "skill",
"target_id": "archer_pinning_shot",
"path": "combat_profile.stamina_cost",
"value": 999
}])
