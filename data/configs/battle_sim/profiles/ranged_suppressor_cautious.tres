"frontline_guard": 130,
"harrier_pressure": 105
}

[resource]
script = ExtResource("1_profile")
profile_id = &"ranged_suppressor_cautious"
display_name = "Ranged Suppressor Cautious"
description = "提高撤退与站位价值，并直接修改 ranged_suppressor 的 retreat/pressure 行为参数。"
ai_score_profile = SubResource("Resource_score")
override_patches = Array[Dictionary]([{
