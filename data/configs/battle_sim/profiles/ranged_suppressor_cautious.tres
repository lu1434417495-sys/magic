"state_id": "pressure",
"action_id": "harrier_keep_range",
"path": "desired_min_distance",
"value": 5
}, {
"target_type": "action",
"brain_id": "ranged_suppressor",
"state_id": "pressure",
"action_id": "harrier_keep_range",
"path": "desired_max_distance",
"value": 6
}, {
