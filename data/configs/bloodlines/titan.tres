[resource]
script = ExtResource("1_bloodline")
bloodline_id = &"titan"
display_name = "Titan Blood"
description = "A mythic bloodline carrying the dormant pressure of ancient titans. It is not a normal creation race and must be granted by story, reward, or debug tooling."
stage_ids = Array[StringName]([&"titan_awakened"])
trait_ids = Array[StringName]([])
racial_granted_skills = Array[Resource]([])
attribute_modifiers = Array[Resource]([SubResource("Resource_constitution"), SubResource("Resource_willpower")])
trait_summary = Array[String](["Dormant titan blood: constitution +1, willpower +1.", "Advanced titan growth is handled by bloodline stage or ascension content, not ordinary race selection."])
