proficiency_tags = Array[StringName]([])
vision_tags = Array[StringName]([&"normal_vision"])
save_advantage_tags = Array[StringName]([&"frightened"])
damage_resistances = {}
dialogue_tags = Array[StringName]([&"halfling"])
racial_trait_summary = Array[String](["半身人幸运。", "勇敢。", "半身人灵巧。", "小型体型。"])
