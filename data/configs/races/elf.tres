proficiency_tags = Array[StringName]([&"perception", &"weapon_type_longsword", &"weapon_type_shortsword", &"weapon_type_shortbow", &"weapon_type_longbow"])
vision_tags = Array[StringName]([&"darkvision"])
save_advantage_tags = Array[StringName]([&"charm", &"sleep"])
damage_resistances = {}
dialogue_tags = Array[StringName]([&"elf"])
racial_trait_summary = Array[String](["妖精血统。", "黑暗视觉。", "敏锐感官。", "入定。", "精灵武器训练。"])
