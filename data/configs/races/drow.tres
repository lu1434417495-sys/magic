default_subrace_id = &"lolth_sworn_drow"
subrace_ids = Array[StringName]([&"lolth_sworn_drow", &"seldarine_drow"])
body_size_category = &"medium"
base_speed = 6
trait_ids = Array[StringName]([&"fey_ancestry", &"superior_darkvision", &"trance", &"drow_weapon_training", &"drow_magic"])
proficiency_tags = Array[StringName]([&"weapon_type_rapier", &"weapon_type_shortsword", &"weapon_type_hand_crossbow"])
vision_tags = Array[StringName]([&"superior_darkvision"])
save_advantage_tags = Array[StringName]([&"charm", &"sleep"])
damage_resistances = {}
dialogue_tags = Array[StringName]([&"drow", &"elf"])
racial_trait_summary = Array[String](["妖精血统。", "高级黑暗视觉。", "入定。", "卓尔武器训练。", "卓尔魔法。"])
