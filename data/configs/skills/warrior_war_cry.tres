[resource]
script = ExtResource("5_08i4o")
skill_id = &"warrior_war_cry"
display_name = "战吼"
icon_id = &"warrior_war_cry"
description = "鼓舞自身及周围1格友军，提升攻击检定。冷却较长但AP与体力消耗低廉，对生命值低于一半的同伴效果更显著（熟练度获取翻倍）。高等级延长增益并降低体力消耗，7级时额外赋予意志检定加值。"
max_level = 7
