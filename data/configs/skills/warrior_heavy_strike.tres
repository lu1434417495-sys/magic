display_name = "重击"
icon_id = &"warrior_heavy_strike"
description = "基础近战技能。使用当前近战武器重击目标，基础攻击检定+1，高等级提高命中。命中时追加随等级成长的技能伤害骰，高等级附加破甲与失衡效果。"
level_description_template = "攻击检定{attack}，追加{skill_dice}技能骰。体力消耗{stamina}{{?armor_break}}，命中附加破甲（{armor_duration}TU）{{/armor_break}}{{?stagger}}，二次命中成功时失衡（{stagger_duration}TU）{{/stagger}}"
