[resource]
script = ExtResource("1_skill")
skill_id = &"warrior_heavy_strike"
display_name = "重击"
icon_id = &"warrior_heavy_strike"
description = "基础近战技能。使用当前近战武器重击目标；所有等级攻击检定 -1。0级造成 1d4 伤害，1级造成 1d6 伤害，2级起体力消耗降为 20，3级造成 1d8 伤害并命中附加破甲。"
max_level = 5
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550, 1000, 1600)
tags = Array[StringName]([&"warrior", &"melee", &"output"])
combat_profile = SubResource("Resource_lbg6c")
