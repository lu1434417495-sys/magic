[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/attribute_modifier.gd" id="1_isppr"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_cast_variant_def.gd" id="2_tciq2"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_skill"]

[sub_resource type="Resource" id="Damage"]
script = ExtResource("1_effect")
effect_type = &"damage"
damage_tag = &"force"
max_skill_level = 3
params = {
"dice_bonus": 1,
"dice_count": 1,
"dice_sides": 4
}

[sub_resource type="Resource" id="Damage_L4"]
script = ExtResource("1_effect")
effect_type = &"damage"
damage_tag = &"force"
min_skill_level = 4
max_skill_level = 5
params = {
"dice_bonus": 2,
"dice_count": 1,
"dice_sides": 4
}

[sub_resource type="Resource" id="Damage_L6"]
script = ExtResource("1_effect")
effect_type = &"damage"
damage_tag = &"force"
min_skill_level = 6
max_skill_level = 7
params = {
"dice_bonus": 3,
"dice_count": 1,
"dice_sides": 4
}

[sub_resource type="Resource" id="Damage_L8"]
script = ExtResource("1_effect")
effect_type = &"damage"
damage_tag = &"force"
min_skill_level = 8
max_skill_level = 9
params = {
"dice_bonus": 4,
"dice_count": 1,
"dice_sides": 4
}

[sub_resource type="Resource" id="Damage_L10"]
script = ExtResource("1_effect")
effect_type = &"damage"
damage_tag = &"force"
min_skill_level = 10
max_skill_level = -1
params = {
"dice_bonus": 5,
"dice_count": 1,
"dice_sides": 4
}

[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_arcane_missile"
range_value = 3
mp_cost = 20
stamina_cost = 15
cooldown_tu = 0
attack_roll_bonus = 1
level_overrides = {
1: {
"attack_roll_bonus": 2
},
2: {
"attack_roll_bonus": 3
},
3: {
"attack_roll_bonus": 4,
"max_target_count": 3,
"range_value": 4
},
5: {
"max_target_count": 4,
"range_value": 5
},
6: {
"max_target_count": 5
},
7: {
"max_target_count": 6,
"range_value": 6
},
8: {
"max_target_count": 7
},
9: {
"max_target_count": 8
},
10: {
"max_target_count": 9,
"range_value": 7
}
}
ai_tags = Array[StringName]([&"single_target", &"multi_target", &"reliable"])
target_selection_mode = &"multi_unit"
max_target_count = 2
allow_repeat_target = true
selection_order_mode = &"manual"
effect_defs = Array[ExtResource("1_effect")]([SubResource("Damage"), SubResource("Damage_L4"), SubResource("Damage_L6"), SubResource("Damage_L8"), SubResource("Damage_L10")])

[resource]
script = ExtResource("3_skill")
skill_id = &"mage_arcane_missile"
display_name = "奥术飞弹"
icon_id = &"mage_arcane_missile"
description = "稳定的力场飞弹，可向多个目标发射。等级提升会增加飞弹数量、射程，并降低冷却。"
max_level = 5
non_core_max_level = 3
dynamic_max_level_stat_id = &"profession_rank:mage"
dynamic_max_level_base = 5
dynamic_max_level_per_stat = -2
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000, 17000, 22000, 28000)
tags = Array[StringName]([&"mage", &"magic", &"arcane", &"output"])
growth_tier = &"basic"
attribute_growth_progress = {
"intelligence": 60
}
level_description_template = "射程{range}，攻击检定{hit}，发射{missiles}枚力场飞弹，每发造成{dmg}伤害，可集中于同一目标。消耗1AP/{mp}法力/{stamina}体力，冷却{cooldown}TU  动态最大等级:{dynamic_max_level}"
