[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/attribute_modifier.gd" id="1_isppr"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_cast_variant_def.gd" id="2_tciq2"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_skill"]

[sub_resource type="Resource" id="Damage_l0"]
script = ExtResource("1_effect")
effect_type = &"damage"
max_skill_level = 0
damage_tag = &"magic"
params = {
"dice_count": 2,
"dice_sides": 6
}

[sub_resource type="Resource" id="Damage_l1"]
script = ExtResource("1_effect")
effect_type = &"damage"
min_skill_level = 1
max_skill_level = 2
damage_tag = &"magic"
params = {
"dice_count": 3,
"dice_sides": 6
}

[sub_resource type="Resource" id="Damage_l3"]
script = ExtResource("1_effect")
effect_type = &"damage"
min_skill_level = 3
max_skill_level = 4
damage_tag = &"magic"
params = {
"dice_count": 4,
"dice_sides": 6
}

[sub_resource type="Resource" id="Damage_l5"]
script = ExtResource("1_effect")
effect_type = &"damage"
min_skill_level = 5
max_skill_level = 6
damage_tag = &"magic"
params = {
"dice_count": 5,
"dice_sides": 6
}

[sub_resource type="Resource" id="Damage_l7"]
script = ExtResource("1_effect")
effect_type = &"damage"
min_skill_level = 7
damage_tag = &"magic"
params = {
"dice_count": 6,
"dice_sides": 6
}

[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_arcane_missile"
range_value = 5
mp_cost = 60
cooldown_tu = 10
attack_roll_bonus = 3
level_overrides = {
3: {
"max_target_count": 3,
"range_value": 6
},
5: {
"cooldown_tu": 5,
"range_value": 6
},
7: {
"attack_roll_bonus": 4,
"max_target_count": 4
}
}
ai_tags = Array[StringName]([&"single_target", &"multi_target", &"reliable"])
target_selection_mode = &"multi_unit"
max_target_count = 2
selection_order_mode = &"manual"
effect_defs = Array[ExtResource("1_effect")]([SubResource("Damage_l0"), SubResource("Damage_l1"), SubResource("Damage_l3"), SubResource("Damage_l5"), SubResource("Damage_l7")])

[resource]
script = ExtResource("3_skill")
skill_id = &"mage_arcane_missile"
display_name = "奥术飞弹"
icon_id = &"mage_arcane_missile"
description = "稳定的奥术多目标点射。等级提升会提高飞弹伤害、射程与可锁定目标数。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
tags = Array[StringName]([&"mage", &"magic", &"arcane", &"output"])
growth_tier = &"advanced"
attribute_growth_progress = {
"intelligence": 120,
"willpower": 60
}
level_description_template = "射程{range}，攻击检定{hit}，每个目标造成{dmg}奥术伤害，最多{targets}目标。消耗1AP/{mp}法力，冷却{cooldown}TU"
