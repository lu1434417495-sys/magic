[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_mountain_suppression"
range_value = 2
ap_cost = 1
stamina_cost = 0
aura_cost = 35
cooldown_tu = 100
attack_roll_bonus = -2
level_overrides = {
	5: {
		"aura_cost": 28
	}
}
mastery_trigger_mode = &"skill_damage_dice_max"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_ef0"), SubResource("Resource_ef1"), SubResource("Resource_ef2"), SubResource("Resource_ef3")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_mountain_suppression"
display_name = "山岳镇压"
description = "击倒目标使其下回合移动减半且不能反击。"
max_level = 9
non_core_max_level = 7
mastery_curve = PackedInt32Array(240, 600, 1320, 2400, 3840, 5640, 7800, 10320, 13200)
growth_tier = &"advanced"
attribute_growth_progress = { "strength": 90, "willpower": 90 }
tags = Array[StringName]([&"warrior", &"melee", &"control"])
combat_profile = SubResource("Resource_combat")
