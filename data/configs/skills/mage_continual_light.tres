[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_light_combat")
skill_id = &"mage_continual_light"
target_mode = &"unit"
target_team_filter = &"enemy"
range_value = 5
ap_cost = 2
mp_cost = 70
cooldown_tu = 15
level_overrides = {
3: {
"range_value": 6
},
5: {
"cooldown_tu": 10,
"range_value": 6
},
7: {
"range_value": 7
}
}
mastery_trigger_mode = &"status_applied"
ai_tags = Array[StringName]([&"control", &"debuff", &"breaker"])
effect_defs = Array[ExtResource("1_light_effect")]([SubResource("Blind_l0"), SubResource("Blind_l1"), SubResource("Blind_l3"), SubResource("Blind_l5"), SubResource("Blind_l7")])

[resource]
script = ExtResource("3_light_skill")
skill_id = &"mage_continual_light"
display_name = "恒光术"
icon_id = &"mage_continual_light"
description = "在目标眼前凝成持续强光，豁免失败时致盲、削弱攻击并压制闪避；也可按虹光法球规则破解靛色层。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
tags = Array[StringName]([&"mage", &"magic", &"radiant", &"control", &"debuff", &"breaker"])
growth_tier = &"advanced"
