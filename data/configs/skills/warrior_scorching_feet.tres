[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_dmg"]
script = ExtResource("3_effect")
effect_type = &"damage"
power = 5
damage_tag = &"fire"
params = { "add_weapon_dice": false }

[sub_resource type="Resource" id="Resource_slow"]
script = ExtResource("3_effect")
effect_type = &"status"
status_id = &"slow"
power = 2
duration_tu = 40

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_scorching_feet"
range_value = 3
ap_cost = 1
aura_cost = 15
cooldown_tu = 80
attack_roll_bonus = 0
mastery_trigger_mode = &"status_applied"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_dmg"), SubResource("Resource_slow")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_scorching_feet"
display_name = "灼足"
icon_id = &"warrior_scorching_feet"
description = "灼烧目标双脚，大幅限制其移动能力。"
max_level = 3
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550)
growth_tier = &"basic"
attribute_growth_progress = { "strength": 20, "willpower": 40 }
tags = Array[StringName]([&"warrior", &"melee", &"control", &"fire"])
combat_profile = SubResource("Resource_combat")
