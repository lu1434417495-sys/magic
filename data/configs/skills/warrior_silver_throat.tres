[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_dmg"]
script = ExtResource("3_effect")
effect_type = &"damage"
power = 0
params = { "add_weapon_dice": true, "requires_weapon": true, "use_weapon_physical_damage_tag": true }

[sub_resource type="Resource" id="Status_silence"]
script = ExtResource("3_effect")
effect_type = &"status"
status_id = &"silence_mark"
power = 1
duration_tu = 40

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_silver_throat"
range_value = 1
ap_cost = 1
stamina_cost = 16
cooldown_tu = 160
attack_roll_bonus = 15
mastery_trigger_mode = &"weapon_attack_quality"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_dmg"), SubResource("Status_silence")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_silver_throat"
display_name = "银线封喉"
icon_id = &"warrior_silver_throat"
description = "高命中精准打击，试图沉默敌人。"
max_level = 3
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550)
growth_tier = &"intermediate"
attribute_growth_progress = { "agility": 100, "strength": 20 }
tags = Array[StringName]([&"warrior", &"melee", &"control", &"high_hit"])
combat_profile = SubResource("Resource_combat")
