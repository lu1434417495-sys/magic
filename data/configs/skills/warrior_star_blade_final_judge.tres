[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_star_blade_final_judge"
range_value = 1
ap_cost = 1
stamina_cost = 0
aura_cost = 65
cooldown_tu = 160
attack_roll_bonus = 0
level_overrides = {
	5: {
		"attack_roll_bonus": 1
	},
	8: {
		"aura_cost": 50
	}
}
mastery_trigger_mode = &"skill_damage_dice_max"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_ef0"), SubResource("Resource_ef1"), SubResource("Resource_ef2"), SubResource("Resource_ef3")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_star_blade_final_judge"
display_name = "星刃终裁"
description = "若目标带有3个以上减益，造成320%伤害；否则造成基础伤害+固定威能，并附加虚弱和减速。星刃流派终式。"
max_level = 10
non_core_max_level = 9
mastery_curve = PackedInt32Array(360, 900, 1980, 3600, 5760, 8600, 12000, 16000, 21000, 26900)
growth_tier = &"ultimate"
attribute_growth_progress = { "agility": 140, "strength": 100 }
tags = Array[StringName]([&"warrior", &"melee", &"finisher"])
combat_profile = SubResource("Resource_combat")
