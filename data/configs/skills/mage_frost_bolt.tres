[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_frost_bolt"
range_value = 5
mp_cost = 60
cooldown_tu = 10
attack_roll_bonus = 2
level_overrides = {
3: {
"range_value": 6
},
5: {
"cooldown_tu": 5,
"range_value": 6
},
7: {
"attack_roll_bonus": 3,
"range_value": 7
}
}
ai_tags = Array[StringName]([&"single_target", &"control"])
effect_defs = Array[ExtResource("1_effect")]([SubResource("Damage_l0"), SubResource("Damage_l1"), SubResource("Damage_l3"), SubResource("Damage_l5"), SubResource("Damage_l7"), SubResource("Slow_l3"), SubResource("Slow_l5"), SubResource("Slow_l7")])

[resource]
