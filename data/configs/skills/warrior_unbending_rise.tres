[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_ef0"]
script = ExtResource("3_effect")
effect_type = &"status"
status_id = &"death_ward"
trigger_condition = &"battle_start"
params = {
    "source_skill_id": "warrior_unbending_rise"
}

[sub_resource type="Resource" id="Resource_ef1"]
script = ExtResource("3_effect")
effect_type = &"heal_fatal"
trigger_condition = &"on_fatal_damage"
trigger_status_id = &"death_ward"
params = {
    "base_heal": 8,
    "con_mod_base": 2,
    "con_mod_per_2_levels": 1,
    "heal_per_level": 4
}

[sub_resource type="Resource" id="Resource_ef2"]
script = ExtResource("3_effect")
effect_type = &"erase_status"
trigger_condition = &"on_fatal_damage"
trigger_status_id = &"death_ward"

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_unbending_rise"
range_value = 0
ap_cost = 1
stamina_cost = 0
aura_cost = 30
cooldown_tu = 120
attack_roll_bonus = 0
level_overrides = {
	3: {
		"aura_cost": 24
	}
}
mastery_trigger_mode = &"skill_damage_dice_max"
mastery_amount_mode = &"per_target_rank"
passive_effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_ef0"), SubResource("Resource_ef1"), SubResource("Resource_ef2")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_unbending_rise"
display_name = "不屈复起"
description = "濒死时保留1HP并获得格挡。"
skill_type = &"passive"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(160, 400, 900, 1600, 2600, 3800, 5300)
growth_tier = &"intermediate"
attribute_growth_progress = { "constitution": 80, "willpower": 40 }
tags = Array[StringName]([&"warrior", &"melee", &"survival"])
combat_profile = SubResource("Resource_combat")
