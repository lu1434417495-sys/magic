[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_dispel_combat")
skill_id = &"mage_dispel_magic"
target_mode = &"unit"
target_team_filter = &"any"
range_value = 6
ap_cost = 2
mp_cost = 60
cooldown_tu = 10
level_overrides = {
3: {
"range_value": 7
},
5: {
"cooldown_tu": 5,
"range_value": 7
},
7: {
"range_value": 8
}
}
mastery_trigger_mode = &"effect_applied"
ai_tags = Array[StringName]([&"support", &"debuff", &"breaker", &"dispel"])
effect_defs = Array[ExtResource("1_dispel_effect")]([SubResource("Dispel_l0"), SubResource("Dispel_l1"), SubResource("Dispel_l3"), SubResource("Dispel_l5"), SubResource("Dispel_l7")])

[resource]
script = ExtResource("3_dispel_skill")
skill_id = &"mage_dispel_magic"
display_name = "解除魔法"
icon_id = &"mage_dispel_magic"
description = "解除一个目标身上的魔法效果：友方目标移除可驱散减益，敌方目标移除可驱散增益；也可按虹光法球规则破解紫色层。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
tags = Array[StringName]([&"mage", &"magic", &"support", &"debuff", &"breaker", &"dispel"])
growth_tier = &"advanced"
