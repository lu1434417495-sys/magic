[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_dispel_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_dispel_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_dispel_skill"]

[sub_resource type="Resource" id="Dispel_l0"]
script = ExtResource("1_dispel_effect")
effect_type = &"dispel_magic"
power = 1
max_skill_level = 0
effect_target_team_filter = &"any"
params = {
"breaks_barrier_layer": "violet",
"max_status_removed": 1,
"remove_beneficial_from_enemies": true,
"remove_harmful_from_allies": true
}

