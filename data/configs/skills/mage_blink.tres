[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/attribute_modifier.gd" id="1_0nll5"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_cast_variant_def.gd" id="2_w6kpn"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_skill"]

[sub_resource type="Resource" id="BlinkJump"]
script = ExtResource("1_effect")
effect_type = &"forced_move"
forced_move_mode = &"jump"
forced_move_distance = 5
jump_base_budget = 10
jump_arc_ratio = 0.4

[sub_resource type="Resource" id="Dodge_l3"]
script = ExtResource("1_effect")
effect_type = &"status"
power = 1
min_skill_level = 3
max_skill_level = 6
status_id = &"dodge_bonus_up"
duration_tu = 40

[sub_resource type="Resource" id="Dodge_l7"]
script = ExtResource("1_effect")
effect_type = &"status"
power = 1
min_skill_level = 7
status_id = &"dodge_bonus_up"
duration_tu = 60

[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_blink"
target_mode = &"ground"
target_team_filter = &"ally"
range_value = 3
mp_cost = 80
cooldown_tu = 20
level_overrides = {
3: {
"cooldown_tu": 15,
"range_value": 4
},
5: {
"cooldown_tu": 15,
"range_value": 4
},
7: {
"range_value": 5
}
}
mastery_trigger_mode = &"effect_applied"
ai_tags = Array[StringName]([&"mobility", &"escape"])
effect_defs = Array[ExtResource("1_effect")]([SubResource("BlinkJump"), SubResource("Dodge_l3"), SubResource("Dodge_l7")])

[resource]
script = ExtResource("3_skill")
skill_id = &"mage_blink"
display_name = "闪现术"
icon_id = &"mage_blink"
description = "短距离空间跃迁。使用现有跳跃落点规则验证目标地格，高等级提升距离并获得短暂闪避。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
tags = Array[StringName]([&"mage", &"magic", &"mobility", &"support"])
growth_tier = &"advanced"
attribute_growth_progress = {
"intelligence": 90,
"perception": 20,
"willpower": 70
}
level_description_template = "选地格位移最多{range}格{{?dodge}}，获得dodge_bonus_up（{dodge_duration}TU）{{/dodge}}。消耗1AP/{mp}法力，冷却{cooldown}TU"
