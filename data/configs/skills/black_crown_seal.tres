[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_cast_variant_def.gd" id="1_variant"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="2_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="3_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="4_skill"]

[sub_resource type="Resource" id="Resource_counter_status"]
script = ExtResource("2_effect")
effect_type = &"status"
status_id = &"black_crown_seal_counterattack"
duration_tu = 60
params = {
"counts_as_debuff": true,
"lock_counterattack": true
}

[sub_resource type="Resource" id="Resource_counter_variant"]
script = ExtResource("1_variant")
variant_id = &"counterattack_lock"
display_name = "禁反击"
description = "对 boss 施加 1 回合封印，目标不能反击。"
target_mode = &"unit"
effect_defs = Array[ExtResource("2_effect")]([SubResource("Resource_counter_status")])

[sub_resource type="Resource" id="Resource_crit_status"]
script = ExtResource("2_effect")
effect_type = &"status"
status_id = &"black_crown_seal_crit"
duration_tu = 60
params = {
"counts_as_debuff": true,
"lock_crit": true
}

[sub_resource type="Resource" id="Resource_crit_variant"]
script = ExtResource("1_variant")
variant_id = &"crit_lock"
display_name = "禁暴击"
description = "对 boss 施加 1 回合封印，目标不能暴击。"
target_mode = &"unit"
effect_defs = Array[ExtResource("2_effect")]([SubResource("Resource_crit_status")])

[sub_resource type="Resource" id="Resource_profile"]
script = ExtResource("3_combat")
skill_id = &"black_crown_seal"
target_mode = &"unit"
target_team_filter = &"enemy"
range_value = 5
ap_cost = 1
cast_variants = Array[ExtResource("1_variant")]([SubResource("Resource_counter_variant"), SubResource("Resource_crit_variant")])

[resource]
script = ExtResource("4_skill")
skill_id = &"black_crown_seal"
display_name = "黑冠封印"
icon_id = &"black_crown_seal"
description = "每战 1 次，只能对 boss 施放 1 回合封印：可选择不能反击或不能暴击。"
max_level = 1
mastery_curve = PackedInt32Array(52)
tags = Array[StringName]([&"fate", &"misfortune", &"seal", &"boss"])
combat_profile = SubResource("Resource_profile")
