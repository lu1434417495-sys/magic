[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_wind_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_wind_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_wind_skill"]

[sub_resource type="Resource" id="Push_l0"]
script = ExtResource("1_wind_effect")
effect_type = &"forced_move"
max_skill_level = 0
effect_target_team_filter = &"enemy"
forced_move_mode = &"wind_push"
forced_move_distance = 1

[sub_resource type="Resource" id="Push_l1"]
script = ExtResource("1_wind_effect")
effect_type = &"forced_move"
min_skill_level = 1
max_skill_level = 2
effect_target_team_filter = &"enemy"
forced_move_mode = &"wind_push"
forced_move_distance = 1

[sub_resource type="Resource" id="Push_l3"]
