forced_move_distance = 3

[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_wind_combat")
skill_id = &"mage_gust_of_wind"
target_mode = &"ground"
target_team_filter = &"enemy"
range_value = 1
area_pattern = &"cone"
area_value = 2
ap_cost = 1
mp_cost = 80
cooldown_tu = 20
level_overrides = {
3: {},
5: {
"cooldown_tu": 15
},
7: {
"area_value": 3
}
}
mastery_trigger_mode = &"effect_applied"
ai_tags = Array[StringName]([&"aoe", &"control", &"displacement"])
effect_defs = Array[ExtResource("1_wind_effect")]([SubResource("Push_l0"), SubResource("Push_l1"), SubResource("Push_l3"), SubResource("Push_l5"), SubResource("Push_l7")])

[resource]
script = ExtResource("3_wind_skill")
skill_id = &"mage_gust_of_wind"
display_name = "强风术"
icon_id = &"mage_gust_of_wind"
description = "从施法者前方鼓起强风，锥尖为点击格，范围向外扩张，并沿风向推开敌人。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
