[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_skill"]

[sub_resource type="Resource" id="Effect_body_size"]
script = ExtResource("1_effect")
effect_type = &"body_size_category_override"
status_id = &"titan_giant_form"
body_size_category = &"huge"
duration_tu = 80

[sub_resource type="Resource" id="Combat_profile"]
script = ExtResource("2_combat")
skill_id = &"titan_colossus_form"
target_mode = &"unit"
target_team_filter = &"self"
target_selection_mode = &"self"
range_value = 0
ap_cost = 1
stamina_cost = 18
cooldown_tu = 200
mastery_trigger_mode = &"effect_applied"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("1_effect")]([SubResource("Effect_body_size")])

[resource]
script = ExtResource("3_skill")
skill_id = &"titan_colossus_form"
display_name = "Titan Colossus Form"
icon_id = &"titan_colossus_form"
description = "Briefly manifest a larger titan body during battle, increasing body size to huge until the form expires."
max_level = 1
mastery_curve = PackedInt32Array(20)
tags = Array[StringName]([&"titan", &"ascension", &"giant_form", &"self", &"control"])
learn_source = &"ascension"
combat_profile = SubResource("Combat_profile")
