[resource]
script = ExtResource("5_his0s")
skill_id = &"archer_aimed_shot"
display_name = "精准射击"
icon_id = &"archer_aimed_shot"
description = "稳住呼吸后射出高精度一箭；若目标本回合尚未行动，则暴击率额外 +15%。"
level_description_template = "武器伤害+{skill_dice}技能骰，攻击检定{attack}，射程随武器，消耗1AP/20体力，无冷却"
level_description_configs = {
	"0": {
		"attack": "+1",
		"skill_dice": "1D4"
	},
	"1": {
		"attack": "+1",
		"skill_dice": "1D6"
	},
	"2": {
		"attack": "+2",
		"skill_dice": "1D6"
	},
	"3": {
		"attack": "+2",
		"skill_dice": "1D8"
	},
	"4": {
		"attack": "+3",
		"skill_dice": "1D8"
	},
	"5": {
		"attack": "+3",
		"skill_dice": "2D4"
	}
}
max_level = 5
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550, 1000, 1600)
growth_tier = &"basic"
attribute_growth_progress = {
"agility": 40,
"perception": 20
}
tags = Array[StringName]([&"archer", &"ranged", &"bow", &"output"])
combat_profile = SubResource("Resource_u1vsk")
