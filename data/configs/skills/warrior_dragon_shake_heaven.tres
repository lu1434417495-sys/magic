[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_dragon_shake_heaven"
range_value = 0
area_pattern = &"radius"
area_value = 2
ap_cost = 1
stamina_cost = 0
aura_cost = 55
cooldown_tu = 160
