[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="1_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="2_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="3_skill"]

[sub_resource type="Resource" id="Effect_slow"]
script = ExtResource("1_effect")
effect_type = &"status"
status_id = &"slow"
power = 1
duration_tu = 80

[sub_resource type="Resource" id="Combat_profile"]
script = ExtResource("2_combat")
skill_id = &"titan_domain_pressure"
target_mode = &"ground"
target_team_filter = &"enemy"
range_value = 3
area_pattern = &"radius"
area_value = 2
ap_cost = 1
stamina_cost = 16
cooldown_tu = 160
mastery_trigger_mode = &"status_applied"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("1_effect")]([SubResource("Effect_slow")])

[resource]
script = ExtResource("3_skill")
skill_id = &"titan_domain_pressure"
display_name = "Titan Domain Pressure"
icon_id = &"titan_domain_pressure"
description = "Project titan pressure over a battlefield zone, slowing enemies caught inside it."
max_level = 1
mastery_curve = PackedInt32Array(20)
tags = Array[StringName]([&"titan", &"ascension", &"domain", &"aoe", &"control"])
learn_source = &"ascension"
combat_profile = SubResource("Combat_profile")
