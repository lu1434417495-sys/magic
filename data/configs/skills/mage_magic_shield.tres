[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_magic_shield"
target_team_filter = &"ally"
range_value = 0
mp_cost = 80
cooldown_tu = 20
level_overrides = {
3: {
"range_value": 3
},
5: {
"cooldown_tu": 15
},
7: {
"range_value": 4
}
}
mastery_trigger_mode = &"effect_applied"
ai_tags = Array[StringName]([&"support", &"defense"])
effect_defs = Array[ExtResource("1_effect")]([SubResource("MagicShield_l0"), SubResource("MagicShield_l3"), SubResource("MagicShield_l5"), SubResource("MagicShield_l7"), SubResource("Shield_l5"), SubResource("Shield_l7")])

[resource]
script = ExtResource("3_skill")
skill_id = &"mage_magic_shield"
display_name = "魔力护盾"
icon_id = &"mage_magic_shield"
description = "为自身或盟友施加魔力护盾，使承受的法术/能量伤害减半。高等级附加护盾值。"
max_level = 7
non_core_max_level = 5
