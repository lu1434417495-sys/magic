[resource]
script = ExtResource("5_v7utl")
skill_id = &"warrior_combo_strike"
display_name = "连击"
icon_id = &"warrior_combo_strike"
description = "圣剑连斩的来源技能之一。连续进行武器攻击，每段命中惩罚逐次指数提升。2级起初始体力消耗降至25，4级起降至20。熟练度增长：命中且暴击或武器骰最大值时获得基础熟练度；成功触发第5段连击起，每多一段额外获得翻倍熟练度奖励。满级核心后提供敏捷+50、力量+10的属性成长进度。"
max_level = 5
non_core_max_level = 3
mastery_curve = PackedInt32Array(200, 500, 1100, 2000, 3200)
growth_tier = &"basic"
attribute_growth_progress = {
"agility": 50,
"strength": 10
}
tags = Array[StringName]([&"warrior", &"melee", &"combo"])
combat_profile = SubResource("Resource_8476s")
