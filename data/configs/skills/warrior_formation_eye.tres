[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_terrain"]
script = ExtResource("3_effect")
effect_type = &"terrain_effect"
terrain_effect_id = &"formation_eye"
duration_tu = 80
tick_interval_tu = 40

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_formation_eye"
target_mode = &"ground"
range_value = 3
ap_cost = 1
stamina_cost = 14
cooldown_tu = 160
attack_roll_bonus = 0
mastery_trigger_mode = &"effect_applied"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_terrain")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_formation_eye"
display_name = "阵眼加固"
icon_id = &"warrior_formation_eye"
description = "指定一格为阵眼，友军站在其上获得防御增益。"
max_level = 3
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550)
growth_tier = &"basic"
attribute_growth_progress = { "willpower": 40, "constitution": 20 }
tags = Array[StringName]([&"warrior", &"melee", &"terrain", &"team"])
combat_profile = SubResource("Resource_combat")
