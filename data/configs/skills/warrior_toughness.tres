[gd_resource type="Resource" script_class="SkillDef" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="1_skill"]
[ext_resource type="Script" path="res://scripts/player/progression/attribute_modifier.gd" id="2_modifier"]

[sub_resource type="Resource" id="Resource_character_hp_percent_bonus"]
script = ExtResource("2_modifier")
attribute_id = &"character_hp_max_percent_bonus"
mode = &"flat"
value = 20
source_type = &"skill"
source_id = &"warrior_toughness"

[sub_resource type="Resource" id="Resource_stamina_recovery_percent_bonus"]
script = ExtResource("2_modifier")
attribute_id = &"stamina_recovery_percent_bonus"
mode = &"flat"
value = 50
source_type = &"skill"
source_id = &"warrior_toughness"

[resource]
script = ExtResource("1_skill")
skill_id = &"warrior_toughness"
display_name = "强健"
icon_id = &"warrior_toughness"
description = "战士基础被动。纯人物生命值 +20%；战斗中体力自然恢复提高 50%。装备与临时技能效果提供的生命上限不被放大。"
skill_type = &"passive"
max_level = 1
non_core_max_level = 1
mastery_curve = PackedInt32Array(1)
learn_source = &"profession"
tags = Array[StringName]([&"warrior", &"passive", &"survival"])
attribute_modifiers = Array[Resource]([SubResource("Resource_character_hp_percent_bonus"), SubResource("Resource_stamina_recovery_percent_bonus")])
