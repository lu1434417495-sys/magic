[resource]
script = ExtResource("3_cold_skill")
skill_id = &"mage_cone_of_cold"
display_name = "寒冰锥"
icon_id = &"mage_cone_of_cold"
description = "从施法者前方喷出近端宽、远端收束的极寒锥流；目标以意志进行法术豁免，成功时伤害减半。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
