[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_dmg"]
script = ExtResource("3_effect")
effect_type = &"damage"
power = 11
damage_tag = &"magic"
params = { "add_weapon_dice": false }

[sub_resource type="Resource" id="Resource_charge"]
script = ExtResource("3_effect")
effect_type = &"charge"
params = { "base_distance": 4, "collision_base_damage": 0, "collision_size_gap_damage": 0, "skill_id": "warrior_holy_dragon_charge" }

[sub_resource type="Resource" id="Resource_taunt"]
script = ExtResource("3_effect")
effect_type = &"status"
status_id = &"taunted"
power = 1
duration_tu = 40

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_holy_dragon_charge"
target_mode = &"ground"
range_value = 4
ap_cost = 2
aura_cost = 40
cooldown_tu = 160
attack_roll_bonus = -5
mastery_trigger_mode = &"weapon_attack_quality"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_dmg"), SubResource("Resource_charge"), SubResource("Resource_taunt")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_holy_dragon_charge"
display_name = "圣龙冲阵"
icon_id = &"warrior_holy_dragon_charge"
description = "沿路径冲锋，对路径上敌人造成伤害并挑衅。"
max_level = 3
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550)
growth_tier = &"advanced"
attribute_growth_progress = { "strength": 120, "constitution": 60 }
tags = Array[StringName]([&"warrior", &"melee", &"qi", &"charge", &"tank"])
combat_profile = SubResource("Resource_combat")
