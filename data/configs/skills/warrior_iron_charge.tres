[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_ef0"]
script = ExtResource("3_effect")
effect_type = &"damage"
min_skill_level = 0
max_skill_level = 2
damage_tag = &"physical_slash"
params = {
    "add_weapon_dice": true,
    "requires_weapon": true,
    "use_weapon_physical_damage_tag": true,
    "dice_count": 1,
    "dice_sides": 6,
    "grant_status_id": "combo_stack",
    "grant_status_power": 1,
    "grant_status_duration_tu": 180,
    "grant_status_stack_limit": 20
}

[sub_resource type="Resource" id="Resource_ef1"]
script = ExtResource("3_effect")
effect_type = &"damage"
min_skill_level = 3
max_skill_level = -1
damage_tag = &"physical_slash"
params = {
    "add_weapon_dice": true,
    "requires_weapon": true,
    "use_weapon_physical_damage_tag": true,
    "dice_count": 1,
    "dice_sides": 8,
    "grant_status_id": "combo_stack",
    "grant_status_power": 1,
    "grant_status_duration_tu": 180,
    "grant_status_stack_limit": 20
}

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_iron_charge"
range_value = 2
ap_cost = 1
stamina_cost = 32
cooldown_tu = 20
attack_roll_bonus = 0
level_overrides = {
	2: {
		"stamina_cost": 28
	},
	4: {
		"stamina_cost": 25
	}
}
mastery_trigger_mode = &"skill_damage_dice_max"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_ef0"), SubResource("Resource_ef1")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_iron_charge"
display_name = "铁心突击"
description = "冲向目标邻格攻击，路径无阻伤害提升。"
max_level = 5
non_core_max_level = 3
mastery_curve = PackedInt32Array(100, 250, 550, 1000, 1600)
growth_tier = &"basic"
attribute_growth_progress = { "agility": 30, "strength": 30 }
tags = Array[StringName]([&"warrior", &"melee", &"mobility"])
combat_profile = SubResource("Resource_combat")
