[sub_resource type="Resource" id="Shock"]
script = ExtResource("1_effect")
effect_type = &"status"
power = 1
status_id = &"shocked"
save_dc_mode = &"caster_spell"
save_dc_source_ability = &"intelligence"
save_ability = &"constitution"
save_tag = &"chain_lightning"
duration_tu = 60

[sub_resource type="Resource" id="Chain"]
script = ExtResource("1_effect")
effect_type = &"chain_damage"
effect_target_team_filter = &"any"
params = {
"base_chain_radius": 1,
"bonus_terrain_effect_id": "wet",
"chain_shape": "square",
"prevent_repeat_target": true,
"wet_chain_radius": 2
}

[sub_resource type="Resource" id="Combat"]
script = ExtResource("2_combat")
skill_id = &"mage_chain_lightning"
range_value = 5
ap_cost = 1
mp_cost = 120
cooldown_tu = 60
spell_fate_mode = &"control_roll"
spell_critical_mode = &"mp_refund"
spell_critical_mp_refund_percent = 50
fumble_protection_curve = PackedInt32Array(0, 0, 0, 1, 1, 2, 2, 3)
fumble_protection_extra_mp_percent = 100
ai_tags = Array[StringName]([&"chain", &"aoe", &"setup"])
effect_defs = Array[ExtResource("1_effect")]([SubResource("Damage_l0"), SubResource("Damage_l1"), SubResource("Damage_l3"), SubResource("Damage_l5"), SubResource("Damage_l7"), SubResource("Shock"), SubResource("Chain")])

[resource]
script = ExtResource("3_skill")
skill_id = &"mage_chain_lightning"
display_name = "链式闪击"
icon_id = &"mage_chain_lightning"
description = "单体锁定的进阶雷系法术。命中后向附近所有目标弹射全额雷电伤害并附加感电，不分敌我。湿地会扩大弹射范围。"
max_level = 7
non_core_max_level = 5
mastery_curve = PackedInt32Array(400, 1000, 2200, 4000, 6500, 9500, 13000)
tags = Array[StringName]([&"mage", &"magic", &"lightning", &"aoe", &"output", &"control"])
growth_tier = &"advanced"
attribute_growth_progress = {
"intelligence": 110,
"perception": 20,
"willpower": 50
}
level_description_template = "射程{range_value}，造成{dmg}雷电伤害（{damage_save_text}），并使目标进行{shocked_save_ability_label}豁免；失败则附加{shocked_display_name}（{shocked_duration_tu}TU，强度{shocked_power}）。向范围内全部目标弹射全额伤害，不分敌我。湿地扩大弹射范围。消耗{ap_cost}AP/{mp_cost}法力，冷却{cooldown_tu}TU"
level_description_configs = {
"0": {
"dmg": "4D6"
},
"1": {
"dmg": "5D6"
},
"2": {
"dmg": "5D6"
},
"3": {
"dmg": "6D6"
},
"4": {
"dmg": "6D6"
},
"5": {
"dmg": "7D6"
},
"6": {
"dmg": "7D6"
},
"7": {
"dmg": "8D6"
}
}
combat_profile = SubResource("Combat")
