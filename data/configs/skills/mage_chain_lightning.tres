[sub_resource type="Resource" id="Damage_l0"]
script = ExtResource("1_effect")
effect_type = &"damage"
max_skill_level = 0
damage_tag = &"lightning"
effect_target_team_filter = &"any"
save_dc_mode = &"caster_spell"
save_dc_source_ability = &"intelligence"
save_ability = &"agility"
save_partial_on_success = true
save_tag = &"chain_lightning"
params = {
"dice_count": 4,
"dice_sides": 6
}

