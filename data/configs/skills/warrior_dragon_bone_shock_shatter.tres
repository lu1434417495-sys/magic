[gd_resource type="Resource" script_class="SkillDef" format=3]

[ext_resource type="Script" path="res://scripts/player/progression/combat_effect_def.gd" id="3_effect"]
[ext_resource type="Script" path="res://scripts/player/progression/combat_skill_def.gd" id="4_combat"]
[ext_resource type="Script" path="res://scripts/player/progression/skill_def.gd" id="5_skill"]

[sub_resource type="Resource" id="Resource_ef0"]
script = ExtResource("3_effect")
effect_type = &"damage"
min_skill_level = 0
max_skill_level = 4
params = {
    "add_weapon_dice": true,
    "requires_weapon": true,
    "use_weapon_physical_damage_tag": true,
    "dice_count": 1,
    "dice_sides": 8,
    "grant_status_id": "combo_stack",
    "grant_status_power": 1,
    "grant_status_duration_tu": 180,
    "grant_status_stack_limit": 20
}

[sub_resource type="Resource" id="Resource_ef1"]
script = ExtResource("3_effect")
effect_type = &"damage"
min_skill_level = 5
max_skill_level = -1
params = {
    "add_weapon_dice": true,
    "requires_weapon": true,
    "use_weapon_physical_damage_tag": true,
    "dice_count": 2,
    "dice_sides": 6,
    "grant_status_id": "combo_stack",
    "grant_status_power": 1,
    "grant_status_duration_tu": 180,
    "grant_status_stack_limit": 20
}

[sub_resource type="Resource" id="Resource_ef2"]
script = ExtResource("3_effect")
effect_type = &"status"
min_skill_level = 0
max_skill_level = -1
status_id = &"armor_break"
duration_tu = 60

[sub_resource type="Resource" id="Resource_combat"]
script = ExtResource("4_combat")
skill_id = &"warrior_dragon_bone_shock_shatter"
range_value = 1
ap_cost = 1
stamina_cost = 28
cooldown_tu = 60
attack_roll_bonus = 0
level_overrides = {
	5: {
		"stamina_cost": 22
	}
}
mastery_trigger_mode = &"skill_damage_dice_max"
mastery_amount_mode = &"per_target_rank"
effect_defs = Array[ExtResource("3_effect")]([SubResource("Resource_ef0"), SubResource("Resource_ef1"), SubResource("Resource_ef2")])

[resource]
script = ExtResource("5_skill")
skill_id = &"warrior_dragon_bone_shock_shatter"
display_name = "龙骨震裂"
description = "HP低于50%时额外破防。"
max_level = 9
non_core_max_level = 7
mastery_curve = PackedInt32Array(240, 600, 1320, 2400, 3840, 5640, 7800, 10320, 13200)
growth_tier = &"advanced"
attribute_growth_progress = { "constitution": 70, "strength": 60, "willpower": 50 }
tags = Array[StringName]([&"warrior", &"melee", &"output", &"debuff"])
combat_profile = SubResource("Resource_combat")
